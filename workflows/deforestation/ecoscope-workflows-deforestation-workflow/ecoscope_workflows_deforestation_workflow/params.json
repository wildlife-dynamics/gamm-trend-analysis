    "time_range": {
      "additionalProperties": false,
      "properties": {
        "since": {
          "format": "date-time",
          "title": "Since",
          "type": "string",
          "description": "The start time"
        },
        "until": {
          "format": "date-time",
          "title": "Until",
          "type": "string",
          "description": "The end time"
        },
        "timezone": {
          "allOf": [
            {
              "$ref": "#/$defs/TimezoneInfo"
            }
          ],
          "default": null,
          "title": "Timezone"
        }
      },
      "required": [
        "since",
        "until"
      ],
      "type": "object",
      "description": "Choose the period of time to analyze.",
      "title": "Time Range"
    },
    "roi": {
      "additionalProperties": false,
      "properties": {
        "config": {
          "anyOf": [
            {
              "$ref": "#/$defs/LocalFileSpatialFeatures"
            },
            {
              "$ref": "#/$defs/RemoteFileSpatialFeatures"
            },
            {
              "$ref": "#/$defs/EarthRangerSpatialFeatures"
            }
          ],
          "title": "Spatial Feature Data Source"
        }
      },
      "required": [
        "config"
      ],
      "type": "object",
      "title": "Load Region of Interest"
    },
    "forest_cover_trends": {
      "additionalProperties": false,
      "properties": {
        "tree_cover_threshold": {
          "default": 60.0,
          "title": "Tree Cover Threshold",
          "type": "number",
          "description": "Minimum tree cover percentage (0-100)"
        },
        "scale": {
          "default": 30,
          "title": "Scale",
          "type": "integer",
          "description": "Pixel scale in meters for reduction"
        },
        "max_pixels": {
          "default": 1000000000.0,
          "title": "Max Pixels",
          "type": "number",
          "description": "Maximum pixels for reduction"
        }
      },
      "required": [],
      "type": "object",
      "title": "Extract Forest Cover Trends"
    },
    "gamm_model": {
      "additionalProperties": false,
      "properties": {
        "degree_of_freedom": {
          "default": 20,
          "title": "Degree Of Freedom",
          "type": "integer",
          "description": "Degrees of freedom for spline basis"
        },
        "degree": {
          "default": 3,
          "title": "Degree",
          "type": "integer",
          "description": "Degree of B-spline basis"
        },
        "family": {
          "default": "gaussian",
          "enum": [
            "gaussian",
            "poisson",
            "binomial"
          ],
          "title": "Family",
          "type": "string",
          "description": "Distribution family for GLM"
        }
      },
      "required": [],
      "type": "object",
      "title": "Fit GAMM Model"
    }
  },
  "$defs": {
    "GoogleEarthEngineConnection": {
      "properties": {
        "name": {
          "title": "Data Source",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "title": "GoogleEarthEngineConnection",
      "type": "object"
    },
    "TimezoneInfo": {
      "properties": {
        "label": {
          "title": "Label",
          "type": "string"
        },
        "tzCode": {
          "title": "Tzcode",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "utc": {
          "title": "Utc",
          "type": "string"
        }
      },
      "required": [
        "label",
        "tzCode",
        "name",
        "utc"
      ],
      "title": "TimezoneInfo",
      "type": "object"
    },
    "EarthRangerSpatialFeatures": {
      "properties": {
        "data_source": {
          "description": "Select one of your configured EarthRanger data sources.",
          "title": "Data Source",
          "type": "string"
        },
        "spatial_features_group_name": {
          "description": "Name of the spatial features group in EarthRanger",
          "title": "Spatial Features Group Name",
          "type": "string"
        }
      },
      "required": [
        "data_source",
        "spatial_features_group_name"
      ],
      "title": "EarthRanger",
      "type": "object"
    },
    "LocalFileSpatialFeatures": {
      "properties": {
        "file_path": {
          "description": "Path to geoparquet (.parquet) or geopackage (.gpkg) file",
          "title": "File Path",
          "type": "string"
        },
        "name_column": {
          "description": "Column to use as region name",
          "title": "Name Column",
          "type": "string"
        },
        "layer": {
          "default": null,
          "description": "Layer name (only applicable to geopackage files)",
          "ecoscope:advanced": true,
          "title": "Layer",
          "type": "string"
        }
      },
      "required": [
        "file_path",
        "name_column"
      ],
      "title": "Local File",
      "type": "object"
    },
    "RemoteFileSpatialFeatures": {
      "properties": {
        "url": {
          "description": "URL to geoparquet (.parquet) or geopackage (.gpkg) file",
          "title": "Url",
          "type": "string"
        },
        "name_column": {
          "description": "Column to use as region name",
          "title": "Name Column",
          "type": "string"
        },
        "layer": {
          "default": null,
          "description": "Layer name (only applicable for geopackage files)",
          "ecoscope:advanced": true,
          "title": "Layer",
          "type": "string"
        }
      },
      "required": [
        "url",
        "name_column"
      ],
      "title": "Remote URL",
      "type": "object"
    }
  },
  "uiSchema": {
    "workflow_details": {
      "ui:order": [
        "name",
        "description"
      ]
    },
    "time_range": {
      "ui:order": [
        "since",
        "until",
        "timezone"
      ]
    },
    "forest_cover_trends": {
      "ui:order": [
        "tree_cover_threshold",
        "scale",
        "max_pixels"
      ]
    },
    "gamm_model": {
      "ui:order": [
        "degree_of_freedom",
        "degree",
        "family"
      ]
    },
    "ui:order": [
      "workflow_details",
      "gee_project_name",
      "base_maps",
      "time_range",
      "roi",
      "forest_cover_trends",
      "gamm_model"
    ]
  },
  "additionalProperties": false
}
