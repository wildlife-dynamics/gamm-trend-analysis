{
  "properties": {
    "workflow_details": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "title": "Workflow Name",
          "type": "string"
        },
        "description": {
          "default": "",
          "title": "Workflow Description",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "type": "object",
      "description": "Add information that will help to differentiate this workflow from another.",
      "title": "Set Workflow Details"
    },
    "gee_project_name": {
      "additionalProperties": false,
      "properties": {
        "data_source": {
          "$ref": "#/$defs/GoogleEarthEngineConnection",
          "title": "",
          "description": "Select one of your configured data sources."
        }
      },
      "required": [
        "data_source"
      ],
      "type": "object",
      "title": "Connect to Earth Engine"
    },
    "time_range": {
      "additionalProperties": false,
      "properties": {
        "since": {
          "format": "date-time",
          "title": "Since",
          "type": "string",
          "description": "Start year of the analysis. The Hansen dataset baseline always starts from 2000.",
          "default": "2000-01-01T00:00:00.000Z"
        },
        "until": {
          "format": "date-time",
          "title": "Until",
          "type": "string",
          "description": "End year of the analysis. Depends on the Hansen dataset selected (e.g. UMD/hansen/global_forest_change_2024_v1_12 covers up to 2024)."
        },
        "timezone": {
          "allOf": [
            {
              "$ref": "#/$defs/TimezoneInfo"
            }
          ],
          "default": null,
          "title": "Timezone"
        }
      },
      "required": [
        "since",
        "until"
      ],
      "type": "object",
      "description": "Choose the period of time to analyze.",
      "title": "Time Range"
    },
    "hansen_image": {
      "additionalProperties": false,
      "properties": {
        "var": {
          "title": "",
          "type": "string",
          "default": "UMD/hansen/global_forest_change_2024_v1_12",
          "description": "Hansen Global Forest Change dataset image name."
        }
      },
      "required": [
        "var"
      ],
      "type": "object",
      "title": "Hansen Dataset"
    },
    "Region of Interest": {
      "type": "object",
      "description": "Define the geographic area and grouping for the analysis.",
      "ecoscope:task_group": true,
      "properties": {
        "groupers": {
          "additionalProperties": false,
          "properties": {
            "groupers": {
              "default": null,
              "items": {
                "anyOf": [
                  {
                    "$ref": "#/$defs/ValueGrouper"
                  },
                  {
                    "$ref": "#/$defs/TemporalGrouper"
                  },
                  {
                    "$ref": "#/$defs/SpatialGrouper"
                  }
                ],
                "title": "Group by"
              },
              "title": " ",
              "type": "array",
              "description": "            Specify how the data should be grouped to create the views for your dashboard.\n            This field is optional; if left blank, all the data will appear in a single view.\n            "
            }
          },
          "type": "object",
          "required": [],
          "title": "Set Groupers"
        },
        "roi": {
          "additionalProperties": false,
          "properties": {
            "config": {
              "anyOf": [
                {
                  "$ref": "#/$defs/LocalFileSpatialFeatures"
                },
                {
                  "$ref": "#/$defs/RemoteFileSpatialFeatures"
                },
                {
                  "$ref": "#/$defs/EarthRangerSpatialFeatures"
                }
              ],
              "title": "Spatial Feature Data Source"
            }
          },
          "required": [
            "config"
          ],
          "type": "object",
          "title": "Load Region of Interest"
        }
      }
    },
    "Forest Analysis": {
      "type": "object",
      "description": "Configure forest cover extraction from the Hansen dataset and data export.",
      "ecoscope:task_group": true,
      "properties": {
        "forest_cover_trends": {
          "additionalProperties": false,
          "properties": {
            "tree_cover_threshold": {
              "default": 60.0,
              "title": "Tree Cover Threshold",
              "type": "number",
              "description": "Minimum tree cover percentage (0-100)"
            },
            "scale": {
              "default": 30,
              "title": "Scale",
              "type": "integer",
              "description": "Pixel scale in meters for reduction",
              "ecoscope:advanced": true
            },
            "max_pixels": {
              "default": 1000000000.0,
              "title": "Max Pixels",
              "type": "number",
              "description": "Maximum pixels for reduction",
              "ecoscope:advanced": true
            }
          },
          "required": [],
          "type": "object",
          "title": "Extract Forest Cover Trends"
        },
        "persist_forest_cover_data": {
          "additionalProperties": false,
          "properties": {
            "filetypes": {
              "default": [
                "csv"
              ],
              "items": {
                "enum": [
                  "csv",
                  "gpkg",
                  "geoparquet",
                  "parquet"
                ],
                "type": "string"
              },
              "title": "Filetypes",
              "type": "array",
              "description": "The output format",
              "uniqueItems": true
            }
          },
          "required": [],
          "type": "object",
          "title": "Export Forest Cover Data"
        }
      }
    },
    "Forest Change Map": {
      "type": "object",
      "description": "Configure the forest change map layers and visualization settings.",
      "ecoscope:task_group": true,
      "properties": {
        "forest_layers": {
          "additionalProperties": false,
          "properties": {
            "tree_cover_threshold": {
              "default": 60.0,
              "title": "Tree Cover Threshold",
              "type": "number"
            },
            "opacity": {
              "default": 1.0,
              "title": "Opacity",
              "type": "number"
            }
          },
          "required": [],
          "type": "object",
          "title": "Forest Layer Style"
        },
        "base_map_defs": {
          "additionalProperties": false,
          "properties": {
            "base_maps": {
              "default": [
                {
                  "url": "https://server.arcgisonline.com/ArcGIS/rest/services/World_Topo_Map/MapServer/tile/{z}/{y}/{x}",
                  "opacity": 1,
                  "max_zoom": 20
                },
                {
                  "url": "https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}",
                  "opacity": 0.5,
                  "max_zoom": 20
                }
              ],
              "items": {
                "title": "Base Layer",
                "anyOf": [
                  {
                    "description": "A tiled raster layer loaded on-demand from a URL template (e.g., base maps).",
                    "properties": {
                      "url": {
                        "default": "https://tile.openstreetmap.org/{z}/{x}/{y}.png",
                        "title": "Preset Layer URL",
                        "type": "string",
                        "const": "https://tile.openstreetmap.org/{z}/{x}/{y}.png",
                        "enum": [
                          "https://tile.openstreetmap.org/{z}/{x}/{y}.png"
                        ]
                      },
                      "opacity": {
                        "default": 1,
                        "description": "Set layer transparency from 1 (fully visible) to 0 (hidden).",
                        "maximum": 1.0,
                        "minimum": 0.0,
                        "title": "Layer Opacity",
                        "type": "number"
                      }
                    },
                    "title": "Open Street Map",
                    "type": "object"
                  },
                  {
                    "description": "A tiled raster layer loaded on-demand from a URL template (e.g., base maps).",
                    "properties": {
                      "url": {
                        "default": "https://server.arcgisonline.com/ArcGIS/rest/services/World_Street_Map/MapServer/tile/{z}/{y}/{x}",
                        "title": "Preset Layer URL",
                        "type": "string",
                        "const": "https://server.arcgisonline.com/ArcGIS/rest/services/World_Street_Map/MapServer/tile/{z}/{y}/{x}",
                        "enum": [
                          "https://server.arcgisonline.com/ArcGIS/rest/services/World_Street_Map/MapServer/tile/{z}/{y}/{x}"
                        ]
                      },
                      "opacity": {
                        "default": 1,
                        "description": "Set layer transparency from 1 (fully visible) to 0 (hidden).",
                        "maximum": 1.0,
                        "minimum": 0.0,
                        "title": "Layer Opacity",
                        "type": "number"
                      }
                    },
                    "title": "Roadmap",
                    "type": "object"
                  },
                  {
                    "description": "A tiled raster layer loaded on-demand from a URL template (e.g., base maps).",
                    "properties": {
                      "url": {
                        "default": "https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}",
                        "title": "Preset Layer URL",
                        "type": "string",
                        "const": "https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}",
                        "enum": [
                          "https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}"
                        ]
                      },
                      "opacity": {
                        "default": 1,
                        "description": "Set layer transparency from 1 (fully visible) to 0 (hidden).",
                        "maximum": 1.0,
                        "minimum": 0.0,
                        "title": "Layer Opacity",
                        "type": "number"
                      }
                    },
                    "title": "Satellite",
                    "type": "object"
                  },
                  {
                    "description": "A tiled raster layer loaded on-demand from a URL template (e.g., base maps).",
                    "properties": {
                      "url": {
                        "default": "https://server.arcgisonline.com/ArcGIS/rest/services/World_Topo_Map/MapServer/tile/{z}/{y}/{x}",
                        "title": "Preset Layer URL",
                        "type": "string",
                        "const": "https://server.arcgisonline.com/ArcGIS/rest/services/World_Topo_Map/MapServer/tile/{z}/{y}/{x}",
                        "enum": [
                          "https://server.arcgisonline.com/ArcGIS/rest/services/World_Topo_Map/MapServer/tile/{z}/{y}/{x}"
                        ]
                      },
                      "opacity": {
                        "default": 1,
                        "description": "Set layer transparency from 1 (fully visible) to 0 (hidden).",
                        "maximum": 1.0,
                        "minimum": 0.0,
                        "title": "Layer Opacity",
                        "type": "number"
                      }
                    },
                    "title": "Terrain",
                    "type": "object"
                  },
                  {
                    "description": "A tiled raster layer loaded on-demand from a URL template (e.g., base maps).",
                    "properties": {
                      "url": {
                        "default": "https://tiles.arcgis.com/tiles/POUcpLYXNckpLjnY/arcgis/rest/services/landDx_basemap_tiles_mapservice/MapServer/tile/{z}/{y}/{x}",
                        "title": "Preset Layer URL",
                        "type": "string",
                        "const": "https://tiles.arcgis.com/tiles/POUcpLYXNckpLjnY/arcgis/rest/services/landDx_basemap_tiles_mapservice/MapServer/tile/{z}/{y}/{x}",
                        "enum": [
                          "https://tiles.arcgis.com/tiles/POUcpLYXNckpLjnY/arcgis/rest/services/landDx_basemap_tiles_mapservice/MapServer/tile/{z}/{y}/{x}"
                        ]
                      },
                      "opacity": {
                        "default": 1,
                        "description": "Set layer transparency from 1 (fully visible) to 0 (hidden).",
                        "maximum": 1.0,
                        "minimum": 0.0,
                        "title": "Layer Opacity",
                        "type": "number"
                      }
                    },
                    "title": "LandDx",
                    "type": "object"
                  },
                  {
                    "description": "A tiled raster layer loaded on-demand from a URL template (e.g., base maps).",
                    "properties": {
                      "url": {
                        "default": "https://server.arcgisonline.com/arcgis/rest/services/Elevation/World_Hillshade/MapServer/tile/{z}/{y}/{x}",
                        "title": "Preset Layer URL",
                        "type": "string",
                        "const": "https://server.arcgisonline.com/arcgis/rest/services/Elevation/World_Hillshade/MapServer/tile/{z}/{y}/{x}",
                        "enum": [
                          "https://server.arcgisonline.com/arcgis/rest/services/Elevation/World_Hillshade/MapServer/tile/{z}/{y}/{x}"
                        ]
                      },
                      "opacity": {
                        "default": 1,
                        "description": "Set layer transparency from 1 (fully visible) to 0 (hidden).",
                        "maximum": 1.0,
                        "minimum": 0.0,
                        "title": "Layer Opacity",
                        "type": "number"
                      }
                    },
                    "title": "USGS Hillshade",
                    "type": "object"
                  },
                  {
                    "description": "A tiled raster layer loaded on-demand from a URL template (e.g., base maps).",
                    "properties": {
                      "url": {
                        "default": "https://example.tiles.com/{z}/{x}/{y}.png",
                        "description": "The URL of a publicly accessible tiled raster service.",
                        "pattern": "https?:\\/\\/(www\\.)?[-a-zA-Z0-9@:%._\\+~#=]{1,256}\\.[a-zA-Z0-9()]{1,6}([-a-zA-Z0-9()@:%_\\+.~#?&//=\\{\\}]*)",
                        "title": "Custom Layer URL",
                        "type": "string"
                      },
                      "opacity": {
                        "default": 1,
                        "description": "Set layer transparency from 1 (fully visible) to 0 (hidden).",
                        "maximum": 1.0,
                        "minimum": 0.0,
                        "title": "Custom Layer Opacity",
                        "type": "number"
                      },
                      "max_zoom": {
                        "default": 20,
                        "description": "Set the maximum zoom level to fetch tiles for.",
                        "title": "Custom Layer Max Zoom",
                        "type": "integer"
                      },
                      "min_zoom": {
                        "default": 0,
                        "description": "Set the minimum zoom level to fetch tiles for.",
                        "title": "Custom Layer Min Zoom",
                        "type": "integer"
                      }
                    },
                    "title": "Custom Layer (Advanced)",
                    "type": "object"
                  }
                ]
              },
              "title": " ",
              "type": "array",
              "description": "Select tile layers to use as base layers in map outputs. The first layer in the list will be the bottommost layer displayed.",
              "ecoscope:advanced": true
            }
          },
          "type": "object",
          "required": [],
          "title": "Base Maps"
        },
        "forest_map": {
          "additionalProperties": false,
          "properties": {
            "legend_style": {
              "allOf": [
                {
                  "$ref": "#/$defs/LegendStyle"
                }
              ],
              "default": {
                "placement": "bottom-right"
              },
              "title": "Legend Style",
              "description": "Additional arguments for configuring the legend.",
              "ecoscope:advanced": true
            }
          },
          "type": "object",
          "required": [],
          "title": "Map Settings"
        }
      }
    },
    "Trend Analysis": {
      "type": "object",
      "description": "Configure the GAM trend fitting parameters, data export, and chart output.",
      "ecoscope:task_group": true,
      "properties": {
        "gamm_model": {
          "additionalProperties": false,
          "properties": {
            "metric": {
              "default": "AIC",
              "enum": [
                "AIC",
                "BIC",
                "Euclidean",
                "MSE",
                "R-Squared"
              ],
              "title": "Metric",
              "type": "string",
              "description": "Metric for optimization",
              "ecoscope:advanced": true
            },
            "degree_of_freedom": {
              "default": 10,
              "title": "Degree Of Freedom",
              "type": "integer",
              "description": "Degrees of freedom for spline basis",
              "ecoscope:advanced": true
            },
            "degree": {
              "default": 3,
              "title": "Degree",
              "type": "integer",
              "description": "Degree of B-spline basis",
              "ecoscope:advanced": true
            },
            "family": {
              "default": "Gaussian",
              "enum": [
                "Gaussian",
                "Poisson",
                "Binomial"
              ],
              "title": "Family",
              "type": "string",
              "description": "Distribution family for GLM",
              "ecoscope:advanced": true
            }
          },
          "required": [],
          "type": "object",
          "title": "Trend Fitting"
        },
        "persist_trend_data": {
          "additionalProperties": false,
          "properties": {
            "filetypes": {
              "default": [
                "csv"
              ],
              "items": {
                "enum": [
                  "csv",
                  "gpkg",
                  "geoparquet",
                  "parquet"
                ],
                "type": "string"
              },
              "title": "Filetypes",
              "type": "array",
              "description": "The output format",
              "uniqueItems": true
            }
          },
          "required": [],
          "type": "object",
          "title": "Export Trend Data"
        }
      }
    },
    "Output Titles": {
      "type": "object",
      "description": "Configure the titles displayed on each dashboard output.",
      "ecoscope:task_group": true,
      "properties": {
        "map_widget_title": {
          "additionalProperties": false,
          "properties": {
            "var": {
              "title": "",
              "type": "string"
            }
          },
          "required": [
            "var"
          ],
          "type": "object",
          "title": "Map Title"
        },
        "chart_widget_title": {
          "additionalProperties": false,
          "properties": {
            "var": {
              "title": "",
              "type": "string"
            }
          },
          "required": [
            "var"
          ],
          "type": "object",
          "title": "Chart Title"
        }
      }
    },
    "groupers": {
      "properties": {
        "groupers": {
          "items": {
            "anyOf": [
              {
                "$ref": "#/$defs/ValueGrouper"
              }
            ]
          },
          "default": [
            {
              "index_name": "name"
            }
          ]
        }
      }
    },
    "roi": {
      "properties": {
        "config": {
          "anyOf": [
            {
              "$ref": "#/$defs/LocalFileSpatialFeatures"
            },
            {
              "$ref": "#/$defs/RemoteFileSpatialFeatures"
            }
          ]
        }
      }
    },
    "map_widget_title": {
      "properties": {
        "var": {
          "default": "Forest Change Map",
          "title": "Map Title"
        }
      }
    },
    "chart_widget_title": {
      "properties": {
        "var": {
          "default": "Forest Cover Trend Chart",
          "title": "Chart Title"
        }
      }
    },
    "persist_forest_cover_data": {
      "properties": {
        "filetypes": {
          "default": [
            "parquet"
          ],
          "items": {
            "enum": [
              "csv",
              "parquet"
            ]
          }
        }
      }
    },
    "persist_trend_data": {
      "properties": {
        "filetypes": {
          "default": [
            "parquet"
          ],
          "items": {
            "enum": [
              "csv",
              "parquet"
            ]
          }
        }
      }
    }
  },
  "$defs": {
    "GoogleEarthEngineConnection": {
      "properties": {
        "name": {
          "title": "Data Source",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "title": "GoogleEarthEngineConnection",
      "type": "object"
    },
    "TimezoneInfo": {
      "properties": {
        "label": {
          "title": "Label",
          "type": "string"
        },
        "tzCode": {
          "title": "Tzcode",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "utc": {
          "title": "Utc",
          "type": "string"
        }
      },
      "required": [
        "label",
        "tzCode",
        "name",
        "utc"
      ],
      "title": "TimezoneInfo",
      "type": "object"
    },
    "SpatialGrouper": {
      "properties": {
        "spatial_index_name": {
          "title": "Spatial Regions",
          "type": "string"
        }
      },
      "required": [
        "spatial_index_name"
      ],
      "title": "Spatial",
      "type": "object"
    },
    "TemporalGrouper": {
      "properties": {
        "temporal_index": {
          "oneOf": [
            {
              "const": "%Y",
              "title": "Year (example: 2024)"
            },
            {
              "const": "%B",
              "title": "Month (example: September)"
            },
            {
              "const": "%Y-%m",
              "title": "Year and Month (example: 2023-01)"
            },
            {
              "const": "%j",
              "title": "Day of the year as a number (example: 365)"
            },
            {
              "const": "%d",
              "title": "Day of the month as a number (example: 31)"
            },
            {
              "const": "%A",
              "title": "Day of the week (example: Sunday)"
            },
            {
              "const": "%H",
              "title": "Hour (24-hour clock) as number (example: 22)"
            },
            {
              "const": "%Y-%m-%d",
              "title": "Date (example: 2025-01-31)"
            }
          ],
          "title": "Time",
          "type": "string"
        }
      },
      "required": [
        "temporal_index"
      ],
      "title": "Time",
      "type": "object"
    },
    "ValueGrouper": {
      "properties": {
        "index_name": {
          "oneOf": [
            {
              "const": "name",
              "title": "Region of Interest"
            }
          ],
          "title": "Category",
          "type": "string"
        }
      },
      "required": [
        "index_name"
      ],
      "title": "Category",
      "type": "object"
    },
    "EarthRangerSpatialFeatures": {
      "properties": {
        "data_source": {
          "description": "Select one of your configured EarthRanger data sources.",
          "title": "Data Source",
          "type": "string"
        },
        "spatial_features_group_name": {
          "description": "Name of the spatial features group in EarthRanger",
          "title": "Spatial Features Group Name",
          "type": "string"
        }
      },
      "required": [
        "data_source",
        "spatial_features_group_name"
      ],
      "title": "EarthRanger",
      "type": "object"
    },
    "LocalFileSpatialFeatures": {
      "properties": {
        "file_path": {
          "description": "Path to geoparquet (.parquet) or geopackage (.gpkg) file",
          "title": "File Path",
          "type": "string",
          "default": ""
        },
        "name_column": {
          "description": "Column to use as region name",
          "title": "Name Column",
          "type": "string"
        },
        "layer": {
          "default": null,
          "description": "Layer name (only applicable to geopackage files)",
          "ecoscope:advanced": true,
          "title": "Layer",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "file_path",
        "name_column"
      ],
      "title": "Local File",
      "type": "object"
    },
    "RemoteFileSpatialFeatures": {
      "properties": {
        "url": {
          "description": "URL to geoparquet (.parquet) or geopackage (.gpkg) file",
          "title": "Url",
          "type": "string",
          "default": ""
        },
        "name_column": {
          "description": "Column to use as region name",
          "title": "Name Column",
          "type": "string"
        },
        "layer": {
          "default": null,
          "description": "Layer name (only applicable for geopackage files)",
          "ecoscope:advanced": true,
          "title": "Layer",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "url",
        "name_column"
      ],
      "title": "Remote URL",
      "type": "object"
    },
    "LegendStyle": {
      "description": "Additional legend configuration options applied per map, rather than per layer",
      "properties": {
        "placement": {
          "default": "bottom-right",
          "ecoscope:advanced": true,
          "enum": [
            "top-left",
            "top-right",
            "bottom-left",
            "bottom-right",
            "fill"
          ],
          "title": "Placement",
          "type": "string"
        }
      },
      "title": "LegendStyle",
      "type": "object"
    }
  },
  "uiSchema": {
    "workflow_details": {
      "ui:order": [
        "name",
