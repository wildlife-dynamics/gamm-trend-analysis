{
  "properties": {
    "workflow_details": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "title": "Workflow Name",
          "type": "string"
        },
        "description": {
          "default": "",
          "title": "Workflow Description",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "type": "object",
      "description": "Add information that will help to differentiate this workflow from another.",
      "title": "Set Workflow Details"
    },
    "gee_project_name": {
      "additionalProperties": false,
      "properties": {
        "data_source": {
          "$ref": "#/$defs/GoogleEarthEngineConnection",
          "title": "",
          "description": "Select one of your configured data sources."
        }
      },
      "required": [
        "data_source"
      ],
      "type": "object",
      "title": "Connect to Earth Engine"
    },
    "groupers": {
      "additionalProperties": false,
      "properties": {
        "groupers": {
          "default": [
            {
              "index_name": "name"
            }
          ],
          "items": {
            "anyOf": [
              {
                "$ref": "#/$defs/ValueGrouper"
              }
            ],
            "title": "Group by"
          },
          "title": " ",
          "type": "array",
          "description": "            Specify how the data should be grouped to create the views for your dashboard.\n            This field is optional; if left blank, all the data will appear in a single view.\n            "
        }
      },
      "type": "object",
      "required": [],
      "title": "Set Groupers"
    },
    "roi": {
      "additionalProperties": false,
      "properties": {
        "config": {
          "anyOf": [
            {
              "$ref": "#/$defs/LocalFileSpatialFeatures"
            },
            {
              "$ref": "#/$defs/RemoteFileSpatialFeatures"
            }
          ],
          "title": "Spatial Feature Data Source"
        }
      },
      "required": [
        "config"
      ],
      "type": "object",
      "title": "Load Region of Interest"
    },
    "forest_cover_trends": {
      "additionalProperties": false,
      "properties": {
        "tree_cover_threshold": {
          "default": 60.0,
          "title": "Tree Cover Threshold",
          "type": "number",
          "description": "Minimum tree cover percentage (0-100)"
        },
        "scale": {
          "default": 30,
          "title": "Scale",
          "type": "integer",
          "description": "Pixel scale in meters for reduction",
          "ecoscope:advanced": true
        },
        "max_pixels": {
          "default": 1000000000.0,
          "title": "Max Pixels",
          "type": "number",
          "description": "Maximum pixels for reduction",
          "ecoscope:advanced": true
        },
        "image": {
          "default": "UMD/hansen/global_forest_change_2023_v1_11",
          "title": "Image",
          "type": "string",
          "description": "Google Earth Engine image name."
        },
        "end_year": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "End Year",
          "description": "End year for the trend analysis (e.g. 2023). This must be consistent with the version of the Hansen image selected (e.g. the 2023_v1_11 image covers up to the end of 2023). Note that the Hansen dataset baseline starting point is always the year 2000."
        }
      },
      "required": [],
      "type": "object",
      "title": "Extract Forest Cover Trends"
    },
    "forest_layers": {
      "additionalProperties": false,
      "properties": {
        "tree_cover_threshold": {
          "default": 60.0,
          "title": "Tree Cover Threshold",
          "type": "number"
        },
        "image": {
          "default": "UMD/hansen/global_forest_change_2023_v1_11",
          "title": "Image",
          "type": "string"
        },
        "end_year": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "End Year"
        },
        "opacity": {
          "default": 1.0,
          "title": "Opacity",
          "type": "number"
        }
      },
      "required": [],
      "type": "object",
      "title": "Create Forest Map Layers"
    },
    "base_map_defs": {
      "additionalProperties": false,
      "properties": {
        "base_maps": {
          "default": [
            {
              "url": "https://server.arcgisonline.com/ArcGIS/rest/services/World_Topo_Map/MapServer/tile/{z}/{y}/{x}",
              "opacity": 1,
              "max_zoom": 20
            },
            {
              "url": "https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}",
              "opacity": 0.5,
              "max_zoom": 20
            }
          ],
          "items": {
            "title": "Base Layer",
            "anyOf": [
              {
                "description": "A tiled raster layer loaded on-demand from a URL template (e.g., base maps).",
                "properties": {
                  "url": {
                    "default": "https://tile.openstreetmap.org/{z}/{x}/{y}.png",
                    "title": "Preset Layer URL",
                    "type": "string",
                    "const": "https://tile.openstreetmap.org/{z}/{x}/{y}.png",
                    "enum": [
                      "https://tile.openstreetmap.org/{z}/{x}/{y}.png"
                    ]
                  },
                  "opacity": {
                    "default": 1,
                    "description": "Set layer transparency from 1 (fully visible) to 0 (hidden).",
                    "maximum": 1.0,
                    "minimum": 0.0,
                    "title": "Layer Opacity",
                    "type": "number"
                  }
                },
                "title": "Open Street Map",
                "type": "object"
              },
              {
                "description": "A tiled raster layer loaded on-demand from a URL template (e.g., base maps).",
                "properties": {
                  "url": {
                    "default": "https://server.arcgisonline.com/ArcGIS/rest/services/World_Street_Map/MapServer/tile/{z}/{y}/{x}",
                    "title": "Preset Layer URL",
                    "type": "string",
                    "const": "https://server.arcgisonline.com/ArcGIS/rest/services/World_Street_Map/MapServer/tile/{z}/{y}/{x}",
                    "enum": [
                      "https://server.arcgisonline.com/ArcGIS/rest/services/World_Street_Map/MapServer/tile/{z}/{y}/{x}"
                    ]
                  },
                  "opacity": {
                    "default": 1,
                    "description": "Set layer transparency from 1 (fully visible) to 0 (hidden).",
                    "maximum": 1.0,
                    "minimum": 0.0,
                    "title": "Layer Opacity",
                    "type": "number"
                  }
                },
                "title": "Roadmap",
                "type": "object"
              },
              {
                "description": "A tiled raster layer loaded on-demand from a URL template (e.g., base maps).",
                "properties": {
                  "url": {
                    "default": "https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}",
                    "title": "Preset Layer URL",
                    "type": "string",
                    "const": "https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}",
                    "enum": [
                      "https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}"
                    ]
                  },
                  "opacity": {
                    "default": 1,
                    "description": "Set layer transparency from 1 (fully visible) to 0 (hidden).",
                    "maximum": 1.0,
                    "minimum": 0.0,
                    "title": "Layer Opacity",
                    "type": "number"
                  }
                },
                "title": "Satellite",
                "type": "object"
              },
              {
                "description": "A tiled raster layer loaded on-demand from a URL template (e.g., base maps).",
                "properties": {
                  "url": {
                    "default": "https://server.arcgisonline.com/ArcGIS/rest/services/World_Topo_Map/MapServer/tile/{z}/{y}/{x}",
                    "title": "Preset Layer URL",
                    "type": "string",
                    "const": "https://server.arcgisonline.com/ArcGIS/rest/services/World_Topo_Map/MapServer/tile/{z}/{y}/{x}",
                    "enum": [
                      "https://server.arcgisonline.com/ArcGIS/rest/services/World_Topo_Map/MapServer/tile/{z}/{y}/{x}"
                    ]
                  },
                  "opacity": {
                    "default": 1,
                    "description": "Set layer transparency from 1 (fully visible) to 0 (hidden).",
                    "maximum": 1.0,
                    "minimum": 0.0,
                    "title": "Layer Opacity",
                    "type": "number"
                  }
                },
                "title": "Terrain",
                "type": "object"
              },
              {
                "description": "A tiled raster layer loaded on-demand from a URL template (e.g., base maps).",
                "properties": {
                  "url": {
                    "default": "https://tiles.arcgis.com/tiles/POUcpLYXNckpLjnY/arcgis/rest/services/landDx_basemap_tiles_mapservice/MapServer/tile/{z}/{y}/{x}",
                    "title": "Preset Layer URL",
                    "type": "string",
                    "const": "https://tiles.arcgis.com/tiles/POUcpLYXNckpLjnY/arcgis/rest/services/landDx_basemap_tiles_mapservice/MapServer/tile/{z}/{y}/{x}",
                    "enum": [
                      "https://tiles.arcgis.com/tiles/POUcpLYXNckpLjnY/arcgis/rest/services/landDx_basemap_tiles_mapservice/MapServer/tile/{z}/{y}/{x}"
                    ]
                  },
                  "opacity": {
                    "default": 1,
                    "description": "Set layer transparency from 1 (fully visible) to 0 (hidden).",
                    "maximum": 1.0,
                    "minimum": 0.0,
                    "title": "Layer Opacity",
                    "type": "number"
                  }
                },
                "title": "LandDx",
                "type": "object"
              },
              {
                "description": "A tiled raster layer loaded on-demand from a URL template (e.g., base maps).",
                "properties": {
                  "url": {
                    "default": "https://server.arcgisonline.com/arcgis/rest/services/Elevation/World_Hillshade/MapServer/tile/{z}/{y}/{x}",
                    "title": "Preset Layer URL",
                    "type": "string",
                    "const": "https://server.arcgisonline.com/arcgis/rest/services/Elevation/World_Hillshade/MapServer/tile/{z}/{y}/{x}",
                    "enum": [
                      "https://server.arcgisonline.com/arcgis/rest/services/Elevation/World_Hillshade/MapServer/tile/{z}/{y}/{x}"
                    ]
                  },
                  "opacity": {
                    "default": 1,
                    "description": "Set layer transparency from 1 (fully visible) to 0 (hidden).",
                    "maximum": 1.0,
                    "minimum": 0.0,
                    "title": "Layer Opacity",
                    "type": "number"
                  }
                },
                "title": "USGS Hillshade",
                "type": "object"
              },
              {
                "description": "A tiled raster layer loaded on-demand from a URL template (e.g., base maps).",
                "properties": {
                  "url": {
                    "default": "https://example.tiles.com/{z}/{x}/{y}.png",
                    "description": "The URL of a publicly accessible tiled raster service.",
                    "pattern": "https?:\\/\\/(www\\.)?[-a-zA-Z0-9@:%._\\+~#=]{1,256}\\.[a-zA-Z0-9()]{1,6}([-a-zA-Z0-9()@:%_\\+.~#?&//=\\{\\}]*)",
                    "title": "Custom Layer URL",
                    "type": "string"
                  },
                  "opacity": {
                    "default": 1,
                    "description": "Set layer transparency from 1 (fully visible) to 0 (hidden).",
                    "maximum": 1.0,
                    "minimum": 0.0,
                    "title": "Custom Layer Opacity",
                    "type": "number"
                  },
                  "max_zoom": {
                    "default": 20,
                    "description": "Set the maximum zoom level to fetch tiles for.",
                    "title": "Custom Layer Max Zoom",
                    "type": "integer"
                  },
                  "min_zoom": {
                    "default": 0,
                    "description": "Set the minimum zoom level to fetch tiles for.",
                    "title": "Custom Layer Min Zoom",
                    "type": "integer"
                  }
                },
                "title": "Custom Layer (Advanced)",
                "type": "object"
              }
            ]
          },
          "title": " ",
          "type": "array",
          "description": "Select tile layers to use as base layers in map outputs. The first layer in the list will be the bottommost layer displayed.",
          "ecoscope:advanced": true
        }
      },
      "type": "object",
      "required": [],
      "title": "Set Base Maps"
    },
    "forest_map": {
      "additionalProperties": false,
      "properties": {
        "static": {
          "default": false,
          "title": "Static",
          "type": "boolean",
          "description": "Set to true to disable map pan/zoom."
        },
        "legend_style": {
          "allOf": [
            {
              "$ref": "#/$defs/LegendStyle"
            }
          ],
          "default": {
            "placement": "bottom-right"
          },
          "title": "Legend Style",
          "description": "Additional arguments for configuring the legend.",
          "ecoscope:advanced": true
        },
        "max_zoom": {
          "default": 20,
          "title": "Max Zoom",
          "type": "integer",
          "description": "            The maximum zoom level allowed by the map.\n            This setting will be overridden if provided\n            tile layers max zoom levels are lower than this value.\n            ",
          "ecoscope:advanced": true
        },
        "view_state": {
          "allOf": [
            {
              "$ref": "#/$defs/ViewState"
            }
          ],
          "default": {
            "longitude": 0,
            "latitude": 0,
            "zoom": 0,
            "pitch": 0,
            "bearing": 0
          },
          "title": "View State",
          "description": "Manually set the view state of the map.",
          "ecoscope:advanced": true
        }
      },
      "type": "object",
      "required": [],
      "title": "Create Forest Change Map"
    },
    "gamm_model": {
      "additionalProperties": false,
      "properties": {
        "metric": {
          "default": "AIC",
          "enum": [
            "AIC",
            "BIC",
            "Euclidean",
            "MSE",
            "R-Squared"
          ],
          "title": "Metric",
          "type": "string",
          "description": "Metric for optimization"
        },
        "degree_of_freedom": {
          "default": 20,
          "title": "Degree Of Freedom",
          "type": "integer",
          "description": "Degrees of freedom for spline basis"
        },
        "degree": {
          "default": 3,
          "title": "Degree",
          "type": "integer",
          "description": "Degree of B-spline basis"
        },
        "family": {
          "default": "Gaussian",
          "enum": [
            "Gaussian",
            "Poisson",
            "Binomial"
          ],
          "title": "Family",
          "type": "string",
          "description": "Distribution family for GLM"
        }
      },
      "required": [],
      "type": "object",
      "title": "Fit GAMM Model"
    }
  },
  "$defs": {
    "GoogleEarthEngineConnection": {
      "properties": {
        "name": {
          "title": "Data Source",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "title": "GoogleEarthEngineConnection",
      "type": "object"
    },
    "SpatialGrouper": {
      "properties": {
        "spatial_index_name": {
          "title": "Spatial Regions",
          "type": "string"
        }
      },
      "required": [
        "spatial_index_name"
      ],
      "title": "Spatial",
      "type": "object"
    },
    "TemporalGrouper": {
      "properties": {
        "temporal_index": {
          "oneOf": [
            {
              "const": "%Y",
              "title": "Year (example: 2024)"
            },
            {
              "const": "%B",
              "title": "Month (example: September)"
            },
            {
              "const": "%Y-%m",
              "title": "Year and Month (example: 2023-01)"
            },
            {
              "const": "%j",
              "title": "Day of the year as a number (example: 365)"
            },
            {
              "const": "%d",
              "title": "Day of the month as a number (example: 31)"
            },
            {
              "const": "%A",
              "title": "Day of the week (example: Sunday)"
            },
            {
              "const": "%H",
              "title": "Hour (24-hour clock) as number (example: 22)"
            },
            {
              "const": "%Y-%m-%d",
              "title": "Date (example: 2025-01-31)"
            }
          ],
          "title": "Time",
          "type": "string"
        }
      },
      "required": [
        "temporal_index"
      ],
      "title": "Time",
      "type": "object"
    },
    "ValueGrouper": {
      "properties": {
        "index_name": {
          "oneOf": [
            {
              "const": "name",
              "title": "Region of Interest"
            }
          ],
          "title": "Category",
          "type": "string"
        }
      },
      "required": [
        "index_name"
      ],
      "title": "Category",
      "type": "object"
    },
    "EarthRangerSpatialFeatures": {
      "properties": {
        "data_source": {
          "description": "Select one of your configured EarthRanger data sources.",
          "title": "Data Source",
          "type": "string"
        },
        "spatial_features_group_name": {
          "description": "Name of the spatial features group in EarthRanger",
          "title": "Spatial Features Group Name",
          "type": "string"
        }
      },
      "required": [
        "data_source",
        "spatial_features_group_name"
      ],
      "title": "EarthRanger",
      "type": "object"
    },
    "LocalFileSpatialFeatures": {
      "properties": {
        "file_path": {
          "description": "Path to geoparquet (.parquet) or geopackage (.gpkg) file",
          "title": "File Path",
          "type": "string",
          "default": ""
        },
        "name_column": {
          "description": "Column to use as region name",
          "title": "Name Column",
          "type": "string"
        },
        "layer": {
          "default": null,
          "description": "Layer name (only applicable to geopackage files)",
          "ecoscope:advanced": true,
          "title": "Layer",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "file_path",
        "name_column"
      ],
      "title": "Local File",
      "type": "object"
    },
    "RemoteFileSpatialFeatures": {
      "properties": {
        "url": {
          "description": "URL to geoparquet (.parquet) or geopackage (.gpkg) file",
          "title": "Url",
          "type": "string",
          "default": ""
        },
        "name_column": {
          "description": "Column to use as region name",
          "title": "Name Column",
          "type": "string"
        },
        "layer": {
          "default": null,
          "description": "Layer name (only applicable for geopackage files)",
          "ecoscope:advanced": true,
          "title": "Layer",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "url",
        "name_column"
      ],
      "title": "Remote URL",
      "type": "object"
    },
    "LegendStyle": {
      "description": "Additional legend configuration options applied per map, rather than per layer",
      "properties": {
        "placement": {
          "default": "bottom-right",
          "ecoscope:advanced": true,
          "enum": [
            "top-left",
            "top-right",
            "bottom-left",
            "bottom-right",
            "fill"
          ],
          "title": "Placement",
          "type": "string"
        }
      },
      "title": "LegendStyle",
      "type": "object"
    },
    "ViewState": {
      "description": "Represents a deck.gl view state",
      "properties": {
        "longitude": {
          "default": 0,
          "ecoscope:advanced": true,
          "maximum": 180.0,
          "minimum": -180.0,
          "title": "Longitude",
          "type": "number"
        },
        "latitude": {
          "default": 0,
          "ecoscope:advanced": true,
          "maximum": 90.0,
          "minimum": -90.0,
          "title": "Latitude",
          "type": "number"
        },
        "zoom": {
          "default": 0,
          "ecoscope:advanced": true,
          "maximum": 20.0,
          "minimum": 0.0,
          "title": "Zoom",
          "type": "number"
        },
        "pitch": {
          "default": 0,
          "ecoscope:advanced": true,
          "maximum": 60.0,
          "minimum": 0.0,
          "title": "Pitch",
          "type": "number"
        },
        "bearing": {
          "default": 0,
          "ecoscope:advanced": true,
          "maximum": 360.0,
          "title": "Bearing",
          "type": "number"
        }
      },
      "title": "ViewState",
      "type": "object"
    }
  },
  "uiSchema": {
    "workflow_details": {
      "ui:order": [
        "name",
        "description"
      ]
    },
    "forest_cover_trends": {
      "ui:order": [
        "tree_cover_threshold",
        "scale",
        "max_pixels",
        "image",
        "end_year"
      ]
    },
    "forest_layers": {
      "ui:order": [
        "tree_cover_threshold",
        "image",
        "end_year",
        "opacity"
      ]
    },
    "forest_map": {
      "ui:order": [
        "static",
        "legend_style",
        "max_zoom",
        "view_state"
      ]
    },
    "gamm_model": {
      "ui:order": [
        "metric",
        "degree_of_freedom",
        "degree",
        "family"
      ]
    },
    "ui:order": [
      "workflow_details",
      "gee_project_name",
      "groupers",
      "roi",
      "forest_cover_trends",
      "forest_layers",
      "base_map_defs",
      "forest_map",
      "gamm_model"
    ]
  },
  "additionalProperties": false
}
